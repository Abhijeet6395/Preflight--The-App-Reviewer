<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- score-gauge arc, open at the bottom like the in-app ScoreRing -->
    <path
        android:pathData="M41,76.5 A26,26 0 1 1 67,76.5"
        android:fillColor="#00000000"
        android:strokeWidth="9"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="28"
                android:startY="80"
                android:endX="80"
                android:endY="28">
                <item android:offset="0" android:color="#FF8B7CF6" />
                <item android:offset="1" android:color="#FF4FE3FD" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- gauge needle dot in the bottom gap -->
    <path
        android:pathData="M54,80 m-4,0 a4,4 0 1,1 8,0 a4,4 0 1,1 -8,0"
        android:fillColor="#FF8B7CF6" />

    <!-- verdict check -->
    <path
        android:pathData="M44,55 L51.5,62.5 L65,46.5"
        android:fillColor="#00000000"
        android:strokeColor="#FF34D399"
        android:strokeWidth="7"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
